{
  "name": "agri-lien",
  "version": "1.0.0",
  "description": "Plateforme de connexion entre fermiers et acheteurs au Bénin",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postbuild": "npm run db:migrate",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:test": "ts-node scripts/test-database.ts",
    "db:seed": "ts-node scripts/seed-database.ts",
    "seed": "npm run db:seed",
    "backup": "ts-node --project tsconfig.scripts.json scripts/backup-database.ts",
    "db:migrate": "ts-node --project tsconfig.scripts.json scripts/db-manager.ts migrate",
    "db:rollback": "ts-node --project tsconfig.scripts.json scripts/db-manager.ts rollback",
    "db:status": "ts-node --project tsconfig.scripts.json scripts/db-manager.ts status",
    "db:reset": "ts-node --project tsconfig.scripts.json scripts/db-manager.ts reset",
    "docker:build": "./scripts/docker-deploy.sh",
    "docker:test": "./scripts/test-docker.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:health": "ts-node --project tsconfig.scripts.json scripts/db-manager.ts health",
    "migrate-data": "ts-node --project tsconfig.scripts.json scripts/migrate-data.ts",
    "backup:create": "ts-node --project tsconfig.scripts.json scripts/backup-database.ts create",
    "backup:list": "ts-node --project tsconfig.scripts.json scripts/backup-database.ts list",
    "backup:restore": "ts-node --project tsconfig.scripts.json scripts/backup-database.ts restore",
    "backup:cleanup": "ts-node --project tsconfig.scripts.json scripts/backup-database.ts cleanup",
    "docker:db": "docker-compose up -d postgres redis pgadmin",
    "services:start": "bash scripts/start-dev-services.sh",
    "services:stop": "bash scripts/stop-dev-services.sh",
    "services:clean": "bash scripts/stop-dev-services.sh --clean",
    "render:prepare": "bash scripts/prepare-render.sh",
    "render:test": "npm run build && npm run db:health"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.17.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "commander": "^14.0.3",
    "date-fns": "^3.2.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.316.0",
    "next": "^14.1.0",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "recharts": "^2.10.4",
    "socket.io-client": "^4.6.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
