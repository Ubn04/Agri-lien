# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Database PostgreSQL
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/agrilien
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrilien
DB_USER=postgres
DB_PASSWORD=postgres123
DATABASE_POOL_SIZE=10

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Payments - Mobile Money
MOMO_API_KEY=your-momo-api-key
MOMO_API_SECRET=your-momo-api-secret
MOMO_CALLBACK_URL=http://localhost:3000/api/payments/callback

# USSD Gateway
USSD_API_KEY=your-ussd-api-key
USSD_SHORT_CODE=*123*456#
USSD_GATEWAY_URL=https://ussd-gateway.example.com

# SMS Notifications
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=AGRILIEN

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@agrilien.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@agrilien.com

# Storage
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_BUCKET=agrilien-uploads

# Maps & Geolocation
MAPBOX_ACCESS_TOKEN=your-mapbox-token
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
SENTRY_DSN=your-sentry-dsn

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
