# Variables d'environnement pour la production Render
# À configurer dans l'interface Render, pas dans ce fichier !

# Application
NEXT_PUBLIC_APP_URL=https://votre-app.onrender.com
NEXT_PUBLIC_API_URL=https://votre-app.onrender.com/api
NEXT_PUBLIC_WS_URL=wss://votre-app.onrender.com

# Base de données (sera fournie par Render PostgreSQL)
# DATABASE_URL=postgresql://username:password@host:port/database
DATABASE_POOL_SIZE=10

# Authentification (générer des clés sécurisées)
# JWT_SECRET=votre-clé-jwt-secrète-très-sécurisée-de-32-caractères-minimum
JWT_EXPIRES_IN=7d
# REFRESH_TOKEN_SECRET=votre-refresh-token-secret-différent-du-jwt
REFRESH_TOKEN_EXPIRES_IN=30d

# Paiements Mobile Money (à obtenir auprès des opérateurs)
# MOMO_API_KEY=votre-clé-momo-api
# MOMO_API_SECRET=votre-secret-momo-api
# MOMO_CALLBACK_URL=https://votre-app.onrender.com/api/payments/callback

# USSD Gateway (à configurer avec l'opérateur telecom)
# USSD_API_KEY=votre-clé-ussd
# USSD_SHORT_CODE=*123*456#
# USSD_GATEWAY_URL=https://votre-gateway-ussd.com

# SMS Notifications (Twilio, African SMS providers, etc.)
# SMS_API_KEY=votre-clé-sms
SMS_SENDER_ID=AGRILIEN

# Email SMTP (Gmail, SendGrid, etc.)
# SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASSWORD=votre-mot-de-passe-app
EMAIL_FROM=noreply@agrilien.com

# Stockage (local par défaut, ou AWS S3)
STORAGE_TYPE=local
# AWS_ACCESS_KEY_ID=votre-aws-key  
# AWS_SECRET_ACCESS_KEY=votre-aws-secret
# AWS_REGION=us-east-1
# AWS_BUCKET=agrilien-uploads

# Maps & Géolocalisation
# MAPBOX_ACCESS_TOKEN=votre-token-mapbox
# GOOGLE_MAPS_API_KEY=votre-clé-google-maps

# Analytics (optionnel)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# IMPORTANT: 
# - Ne jamais commiter les vraies valeurs dans Git
# - Configurer toutes ces variables dans l'interface Render
# - Générer des clés sécurisées pour JWT et autres secrets